# ═══════════════════════════════════════════════════════
# Backend-specific
# (le reste est dans ../.env racine, lu via docker-compose env_file)
# ═══════════════════════════════════════════════════════

# --- Database
# Doit matcher les POSTGRES_* de ../.env
# Hostname "db" = nom du service dans docker-compose.yml (pas localhost)
DATABASE_URL="postgresql://user:password@db:5432/transcendence"

# --- Server
PORT=4000

# --- 42 OAuth
# Credentials depuis https://profile.intra.42.fr/oauth/applications
FORTYTWO_CLIENT_ID=""
FORTYTWO_CLIENT_SECRET=""
FORTYTWO_CALLBACK_URL="https://localhost/api/auth/42/callback"