# ═══════════════════════════════════════════════════════
# Configuration partagée entre tous les services
# (lue par docker-compose + backend + frontend)
# ═══════════════════════════════════════════════════════
#
# En dev:  make setup  -> génère .env depuis build.mk automatiquement
# Sans make: cp .env.example .env  -> puis éditer les GENERATE_ME à la main

# --- Mode (development | production)
# dev  : THROTTLER_DISABLED=true, logs verbeux, helmet relaché
# prod : tout strict, pas de bypass
ENV_MODE=development

# --- Network
DOMAIN_NAME=localhost
CORS_ORIGIN=https://localhost
FRONTEND_PORT=3000
BACKEND_PORT=4000

# --- Frontend (NEXT_PUBLIC_*)
# Inlines par Next.js a la compilation -> compose.yml les passe en build args.
# Egalement lus au runtime par les composants serveur via env_file.
NEXT_PUBLIC_API_URL=https://localhost/api
NEXT_PUBLIC_SOCKET_URL=https://localhost
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# --- PostgreSQL (lu par docker-compose pour créer la DB)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=transcendence

# --- JWT (partagé backend + frontend proxy Next.js)
# Génère avec: openssl rand -hex 64
JWT_SECRET="GENERATE_ME_with_openssl_rand_hex_64"
JWT_EXPIRATION="3h"
JWT_REFRESH_EXPIRATION="7d"

# --- 2FA TOTP : clé de chiffrement AES-256-GCM du secret en DB
# Génère avec: openssl rand -hex 32
TWO_FA_ENCRYPTION_KEY="GENERATE_ME_with_openssl_rand_hex_32"

# --- Throttler (rate limiting)
# true  = bypass complet (utile pour make tests + dev intensif)
# false = actif (à mettre en prod)
THROTTLER_DISABLED=true

# --- 42 OAuth (optionnel, si pas configure -> bouton 42 cache cote front)
FORTYTWO_CLIENT_ID=disabled
FORTYTWO_CLIENT_SECRET=
FORTYTWO_CALLBACK_URL=https://localhost/api/auth/42/callback
